# Copy this file to .env and fill in your values.
# cp example.env .env

# === Required ===
WHATSAPP_CLOUD_API_ACCESS_TOKEN=your_access_token_here
WHATSAPP_CLOUD_API_PHONENUMBER_ID=your_phone_number_id_here

# === Optional (defaults shown) ===
WHATSAPP_CLOUD_API_BASE_URL=https://graph.facebook.com
WHATSAPP_CLOUD_API_API_VERSION=v22.0
WHATSAPP_CLOUD_API_BUSINESS_ACCOUNT_ID=
WHATSAPP_CLOUD_API_APP_SECRET=
WHATSAPP_CLOUD_API_APP_ID=
WHATSAPP_CLOUD_API_SECURE_REQUESTS=false
WHATSAPP_CLOUD_API_DEBUG_LOG_LEVEL=

# === Test recipients ===
WHATSAPP_CLOUD_API_TEST_SENDER=
WHATSAPP_CLOUD_API_TEST_RECEIVER=
